# SADA Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-secure-jwt-secret-here

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sada
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sada

# Apple Sign-In
APPLE_BUNDLE_ID=com.sada.app
APPLE_CLIENT_ID=com.sada.app

# Push Notifications (Expo)
PUSH_NOTIFICATION_KEY=

# Cloudflare TURN (WebRTC)
CLOUDFLARE_APP_ID=
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Calls SFU (used for audio routing - NOT the same as API token)
# Find this in Cloudflare Dashboard > Calls > your app settings
CLOUDFLARE_APP_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=5

# Logging
LOG_LEVEL=info

# Domain (production only)
# VIRTUAL_HOST=sada.example.com
# LETSENCRYPT_HOST=sada.example.com
# LETSENCRYPT_EMAIL=admin@example.com
