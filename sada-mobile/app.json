{
  "expo": {
    "name": "sada-mobile",
    "slug": "sada-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bitcode": false,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.anonymous.sada-mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SADA needs microphone access for live audio rooms.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "audio",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.sadamobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "appleAudioCategory": "PlayAndRecord",
          "appleAudioMode": "voiceChat",
          "appleAudioCategoryOptions": [
            "AllowBluetooth",
            "DefaultToSpeaker"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0a61c2c8-d8ff-4440-ac38-c14f08f281ad"
      },
      "apiUrl": "https://sada.mustafin.dev/api"
    }
  }
}
